PORT=3000

# Destination inbox for bug reports
REPORT_TO_EMAIL=your-email@example.com

# SMTP transport settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# OAuth2 app/user settings
OAUTH_USER=your-email@gmail.com
OAUTH_CLIENT_ID=your-google-oauth-client-id
OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
OAUTH_REFRESH_TOKEN=your-google-oauth-refresh-token

# Optional (server can refresh token using OAUTH_REFRESH_TOKEN)
OAUTH_ACCESS_TOKEN=

# Optional "from" address shown in sent email (defaults to OAUTH_USER)
SMTP_FROM=your-email@gmail.com
